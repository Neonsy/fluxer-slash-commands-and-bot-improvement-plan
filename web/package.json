{
	"name": "fluxer-bot-platform-prd",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.15.1",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"dev": "astro dev",
		"validate:research": "tsx scripts/validate-research.ts",
		"validate:content": "tsx scripts/validate-sources.ts",
		"validate:copy": "tsx scripts/validate-copy.ts",
		"validate:built-site": "tsx scripts/validate-built-site.ts",
		"check": "pnpm validate:research && pnpm validate:content && pnpm validate:copy && astro check",
		"build": "pnpm validate:research && pnpm validate:content && pnpm validate:copy && astro build && pnpm validate:built-site && pagefind --site dist",
		"preview": "astro preview",
		"test": "vitest run",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@astrojs/sitemap": "3.7.3",
		"astro": "7.1.3"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/markdown-satteri": "0.3.4",
		"@axe-core/playwright": "4.12.1",
		"@playwright/test": "1.61.1",
		"pagefind": "1.5.2",
		"tsx": "4.23.1",
		"typescript": "6.0.3",
		"vitest": "4.1.10"
	}
}
