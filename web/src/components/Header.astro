---
import {sitePath} from '@/lib/routes';

const pathname = Astro.url.pathname;
const planHref = sitePath('/');
const decisionsHref = '/evidence/source/guide/11-open-decisions/';
const decisionsActive = pathname.includes('/guide/11-open-decisions');
const researchActive = pathname.includes('/evidence') && !decisionsActive;
const planActive = pathname === planHref || pathname === planHref.replace(/\/$/, '');
---

<header class="site-header">
	<div class="shell header-inner">
		<a class="brand" href={sitePath('/')} aria-label="Fluxer Bot Platform home">
			<span class="brand-product">Fluxer</span>
			<span class="brand-document">Bot Platform</span>
		</a>

		<nav class="desktop-nav" aria-label="Primary navigation">
			<a class:list={{active: planActive}} href={planHref} aria-current={planActive ? 'page' : undefined}>PRD</a>
			<a class:list={{active: decisionsActive}} href={sitePath(decisionsHref)} aria-current={decisionsActive ? 'page' : undefined}>Open decisions</a>
			<a class:list={{active: researchActive}} href={sitePath('/evidence/')} aria-current={researchActive ? 'page' : undefined}>Technical details</a>
		</nav>

		<details class="mobile-nav">
			<summary>Menu</summary>
			<nav aria-label="Mobile navigation">
				<a class:list={{active: planActive}} href={planHref} aria-current={planActive ? 'page' : undefined}>PRD</a>
				<a class:list={{active: decisionsActive}} href={sitePath(decisionsHref)} aria-current={decisionsActive ? 'page' : undefined}>Open decisions</a>
				<a class:list={{active: researchActive}} href={sitePath('/evidence/')} aria-current={researchActive ? 'page' : undefined}>Technical details</a>
			</nav>
		</details>
	</div>
</header>
