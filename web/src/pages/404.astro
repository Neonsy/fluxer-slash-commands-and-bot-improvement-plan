---
const home = import.meta.env.BASE_URL;
const redirect = `0${String.fromCharCode(59)}url=${home}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="robots" content="noindex,nofollow" />
		<meta http-equiv="refresh" content={redirect} />
		<title>Fluxer Bot Platform</title>
		<script is:inline define:vars={{home}}>window.location.replace(home)</script>
	</head>
	<body></body>
</html>
